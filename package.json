    "baseline-browser-mapping": "^2.10.40",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "fast-xml-parser": "^5.9.3",
    "focus-trap": "^7.8.0",
    "node": "22.23.1",
    "node-forge": "^1.4.0",
    "nuxt": "^4.4.8",
    "nuxt-oidc-auth": "1.0.0-beta.11",
    "papaparse": "^5.5.4",
    "pg": "^8.22.0",
    "scule": "^1.3.0",
    "ssh2-sftp-client": "^12.1.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
