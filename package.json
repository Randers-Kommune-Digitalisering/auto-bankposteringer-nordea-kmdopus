{
  "name": "nuxt_rewrite",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:reset:public": "tsx scripts/db/reset-public-schema.ts",
    "db:seed:system": "tsx scripts/db/seed-system.ts",
    "db:seed:dev": "tsx scripts/db/seed-dev.ts",
    "db:import:transaction-code-catalog": "tsx --tsconfig tsconfig.scripts.json scripts/db/import-transaction-code-catalog.ts",
    "db:unseed:dev": "tsx scripts/db/unseed-dev.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "smoke:sftp": "tsx scripts/smoke/sftp-probe.ts",
    "smoke:banking:ingest:nordea-example": "tsx --tsconfig tsconfig.scripts.json scripts/smoke/ingest-nordea-example.ts",
    "smoke:banking:nordea:rest": "tsx scripts/smoke/nordea-rest.ts",
    "smoke:erp:pipeline": "APP_ROLE=worker tsx --tsconfig tsconfig.scripts.json scripts/smoke/erp-sftp-pipeline.ts",
    "banking:nordea:catalog:camt053:dk": "tsx --tsconfig tsconfig.scripts.json scripts/banking/nordea/generate-camt053-dk-transaction-catalog.ts",
    "banking:nordea:schemas": "tsx scripts/banking/nordea/download-secure-envelope-schemas.ts",
    "banking:pki:create-customer-certs": "tsx scripts/banking/pki/create-customer-certs.ts",
    "banking:danske:verify-root": "tsx scripts/banking/danske/verify-root-zip.ts",
    "banking:danske:pkiws:create-customer-certs": "tsx scripts/banking/danske/pkiws-create-customer-certs.ts",
    "banking:danske:pkiws:smoke-docs": "tsx scripts/banking/danske/pkiws-create-customer-certs.ts --doc-smoke-test",
    "banking:nordea:certificate-enrollment": "tsx scripts/banking/pki/create-customer-certs.ts --provider nordea"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.115",
