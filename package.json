    "@nuxt/test-utils": "^4.0.3",
    "@types/node-forge": "^1.3.14",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/xml2js": "^0.4.14",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.9"
