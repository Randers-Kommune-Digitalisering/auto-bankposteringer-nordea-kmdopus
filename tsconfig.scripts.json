{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "types": ["node"],
    "paths": {
      "~/*": ["app/*"],
      "@/*": ["app/*"],
      "~~/*": ["./*"] ,
      "@@/*": ["./*"] ,
      "#engine/*": ["engine/*"]
    }
  }
}
